# --- Frontend (Vite, client-exposed → VITE_ prefix verplicht) ---
# Anon/publishable key is publiek-veilig zolang RLS aanstaat. Service-role NOOIT als VITE_-var.
VITE_SUPABASE_URL=https://<drafter-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Base-pad voor Edge Functions (Supabase functions endpoint)
VITE_DRAFTER_FUNCTIONS_BASE=https://<drafter-project-ref>.supabase.co/functions/v1

# --- Edge Functions (server-side, NOOIT VITE_ prefix, gezet in Supabase secrets/Vault) ---
# ANTHROPIC_API_KEY  → via Vault skill:legalmind-word-addin:anthropic_api_key
# SUPABASE_SERVICE_ROLE_KEY → automatisch beschikbaar in Edge Function runtime

<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Drafter — Legal Mind Word add-in (PRODUCTIE-manifest).
  Wijst naar de gehoste Vercel-URL. Voor lokale dev: gebruik manifest.local.xml (localhost:3000).
  Bron-van-waarheid voor de add-in-identiteit is de <Id> GUID hieronder — wijzig die NOOIT na publicatie.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <Id>d3a7f1e2-9b4c-4e6a-8f2d-1c5b7a9e0d34</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Legal Mind</ProviderName>
  <DefaultLocale>nl-NL</DefaultLocale>
  <DisplayName DefaultValue="Drafter — Legal Mind"/>
  <Description DefaultValue="Legal-AI assistent in Word: stel juridische vragen, laat passages herschrijven en accepteer wijzigingen via Track Changes."/>
  <IconUrl DefaultValue="https://drafter.legal-mind.nl/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://drafter.legal-mind.nl/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://drafter.legal-mind.nl/"/>

  <AppDomains>
    <AppDomain>https://drafter.legal-mind.nl</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://drafter.legal-mind.nl/"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="Drafter.Group">
                <Label resid="Drafter.GroupLabel"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16"/>
                  <bt:Image size="32" resid="Icon.32"/>
                  <bt:Image size="80" resid="Icon.80"/>
                </Icon>
                <Control xsi:type="Button" id="Drafter.OpenTaskpane">
                  <Label resid="Drafter.OpenLabel"/>
                  <Supertip>
                    <Title resid="Drafter.OpenLabel"/>
                    <Description resid="Drafter.OpenTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>DrafterTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://drafter.legal-mind.nl/assets/icon-16.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://drafter.legal-mind.nl/assets/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://drafter.legal-mind.nl/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://drafter.legal-mind.nl/"/>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://drafter.legal-mind.nl/"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Drafter is geïnstalleerd"/>
        <bt:String id="Drafter.GroupLabel" DefaultValue="Drafter"/>
        <bt:String id="Drafter.OpenLabel" DefaultValue="Drafter openen"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Klik op 'Drafter openen' in het Start-tabblad om de legal-AI assistent te starten."/>
        <bt:String id="Drafter.OpenTooltip" DefaultValue="Open het Drafter-paneel: juridische vragen, herschrijven en Track Changes."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
